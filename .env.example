# Example environment file - copy to .env and fill values
# Do NOT commit your real .env to GitHub

# Wi-Fi (for ESP32 firmware when testing with hardware)
WIFI_SSID=REPLACE_WITH_SSID
WIFI_PASS=REPLACE_WITH_PASSWORD

# ThingSpeak (optional)
THINGSPEAK_API_KEY=REPLACE_WITH_THINGSPEAK_WRITE_KEY

# Blynk (optional)
BLYNK_TOKEN=REPLACE_WITH_BLYNK_TOKEN

# Other service keys (if any)
OTHER_API_KEY=
